# ベースイメージにRed Hat UBI 10を指定
FROM registry.access.redhat.com/ubi10/ubi:latest

# VS Code Dev Containerに必要な基本ツールと、Red Hat公式のOpenJDK 21・Mavenをインストール
RUN dnf update -y && \
    dnf install -y java-21-openjdk-devel maven git sudo tar gzip unzip wget && \
    dnf clean all

# Dev Containerの標準である「vscode」ユーザーを作成し、パスワードなしでsudo可能にする
RUN useradd -m -s /bin/bash vscode && \
    echo "vscode ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

# デフォルトユーザーを指定
USER vscode