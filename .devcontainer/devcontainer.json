{
    "name": "Quarkus UBI10 Dev Container",
    
    "build": {
        "dockerfile": "Containerfile"
    },

    // 1. ボリュームのマウント設定（sourceに好きなボリューム名を指定）
    "workspaceMount": "source=quarkus-workspace-vol,target=/workspaces/quarkus-in-action,type=volume",
    
    // 2. VS Codeを開くデフォルトのディレクトリ（targetと同じパスを指定）
    "workspaceFolder": "/workspaces/quarkus-in-action",

    "forwardPorts": [8080, 5005],

    "customizations": {
        "vscode": {
            "settings": {
                "java.compile.nullAnalysis.mode": "automatic",
                "java.configuration.runtimes": [
                    {
                        "name": "JavaSE-21",
                        "path": "/usr/lib/jvm/java-21-openjdk",
                        "default": true
                    }
                ]
            },
            "extensions": [
                "redhat.java",
                "vscjava.vscode-java-debug",
                "vscjava.vscode-java-test",
                "vscjava.vscode-maven",
                "redhat.vscode-quarkus"
            ]
        }
    },  

    "remoteUser": "vscode",
    "containerUser": "vscode", // 追加

    "runArgs": ["--security-opt", "label=disable"],

    "mounts": [
        "type=bind,source=/dev/null,target=/var/run/docker.sock"
    ]
}